# jit_test.nq — JIT controls, stats, and fallback correctness

assert(jit_enabled() == true, "jit enabled by default")

jit_reset_stats()
let acc = 0
for i = 0 to 10000 step 1
  acc += 1
end
assert(acc == 10000, "jit loop computes correctly")

let stats_after_jit = jit_stats()
assert(type(stats_after_jit) == "string", "jit_stats returns string")
assert(index(stats_after_jit, "attempts=") >= 0, "jit_stats includes attempts")

jit_enable(false)
assert(jit_enabled() == false, "jit can be disabled")

let m = 1
for i = 0 to 10 step 1
  m *= 2
end
assert(m == 1024, "fallback loop with multiply is correct")

jit_enable(true)
assert(jit_enabled() == true, "jit can be enabled again")

print "jit tests OK"
