# array_test.nq — core array operations

let a = [3, 1, 4, 1, 5]
assert(len(a) == 5,          "len array")

push(a, 9)
assert(len(a) == 6,          "push len")
assert(a[5] == 9,            "push value")

let v = pop(a)
assert(v == 9,               "pop value")
assert(len(a) == 5,          "len after pop")

assert(contains(a, 4),       "contains true")
assert(not contains(a, 99),  "contains false")

let s = sort([3,1,2])
assert(s[0] == 1,  "sort[0]")
assert(s[1] == 2,  "sort[1]")
assert(s[2] == 3,  "sort[2]")

assert(join([1,2,3], "-") == "1-2-3", "join")

# negative indexing
let b = [10, 20, 30]
assert(b[-1] == 30, "negative index -1")
assert(b[-2] == 20, "negative index -2")

# remove
let c = [1, 2, 3, 4]
let removed = remove(c, 1)
assert(removed == 2,     "remove value")
assert(len(c) == 3,      "remove len")
assert(c[0] == 1,        "remove shift[0]")
assert(c[1] == 3,        "remove shift[1]")

print "array tests OK"
