let a = [3, 1, 4, 1, 5]
assert(len(a) == 5,        "len array")
push(a, 9)
assert(len(a) == 6,        "push")
assert(a[5] == 9,          "index after push")
let v = pop(a)
assert(v == 9,             "pop value")
assert(len(a) == 5,        "len after pop")
assert(contains(a, 4),     "contains true")
assert(!contains(a, 99),   "contains false")
let s = sort([3,1,2])
assert(s[0] == 1,          "sort[0]")
assert(s[1] == 2,          "sort[1]")
assert(s[2] == 3,          "sort[2]")
assert(join([1,2,3], "-") == "1-2-3", "join")
