assert(1 + 1 == 2,       "addition")
assert(10 - 3 == 7,      "subtraction")
assert(2 * 6 == 12,      "multiplication")
assert(10 / 4 == 2.5,    "division")
assert(10 % 3 == 1,      "modulo")
assert(abs(-5) == 5,     "abs")
assert(sqrt(9) == 3,     "sqrt")
assert(pow(2, 8) == 256, "pow")
assert(max(3, 7) == 7,   "max")
assert(min(3, 7) == 3,   "min")
